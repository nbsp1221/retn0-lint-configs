{
  "name": "retn0-lint-configs",
  "version": "0.0.0",
  "private": true,
  "description": "🧹 My custom linting configuration packages monorepo",
  "keywords": [
    "eslint",
    "eslint-config",
    "oxlint",
    "oxlint-config",
    "lint",
    "linter",
    "monorepo"
  ],
  "license": "MIT",
  "author": "nbsp1221",
  "type": "module",
  "scripts": {
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint",
    "lint:eslint": "eslint .",
    "lint:oxlint": "oxlint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fixtures": "vitest run tests/eslint-config.fixtures.test.ts",
    "test:update-fixtures": "UPDATE_FIXTURES=1 vitest run tests/eslint-config.fixtures.test.ts"
  },
  "devDependencies": {
    "@retn0/eslint-config": "workspace:*",
    "@retn0/oxlint-config": "workspace:*",
    "@types/node": "25.2.3",
    "@types/react": "19.1.8",
    "eslint": "9.29.0",
    "oxlint": "1.3.0",
    "typescript": "5.8.3",
    "vitest": "4.0.18"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.0.0"
  }
}
