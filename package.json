{
  "name": "retn0-lint-configs",
  "version": "0.0.0",
  "private": true,
  "description": "My personal linting and formatting configuration monorepo",
  "keywords": [
    "config",
    "eslint",
    "eslint-config",
    "format",
    "formatter",
    "javascript",
    "lint",
    "linter",
    "monorepo",
    "oxfmt",
    "oxfmt-config",
    "oxlint",
    "oxlint-config",
    "typescript"
  ],
  "license": "MIT",
  "author": "nbsp1221",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . && eslint .",
    "lint:eslint": "eslint .",
    "lint:oxlint": "oxlint .",
    "preformat": "pnpm build",
    "preformat:check": "pnpm build",
    "prelint": "pnpm build",
    "prelint:eslint": "pnpm build",
    "prelint:oxlint": "pnpm build",
    "pretest": "pnpm build",
    "pretest:fixtures": "pnpm build",
    "pretest:update-fixtures": "pnpm build",
    "pretest:watch": "pnpm build",
    "test": "vitest run",
    "test:fixtures": "vitest run tests/eslint-config.fixtures.test.ts",
    "test:update-fixtures": "UPDATE_FIXTURES=1 vitest run tests/eslint-config.fixtures.test.ts",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@retn0/config-policy": "workspace:*",
    "@retn0/eslint-config": "workspace:*",
    "@retn0/eslint-config-oxlint": "workspace:*",
    "@retn0/oxfmt-config": "workspace:*",
    "@retn0/oxlint-config": "workspace:*",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "eslint": "10.5.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.34.3"
}
