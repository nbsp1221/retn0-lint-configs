{
  "name": "retn0-lint-configs",
  "version": "0.0.0",
  "private": true,
  "description": "My personal linting and formatting configuration monorepo",
  "keywords": [
    "config",
    "eslint",
    "eslint-config",
    "format",
    "formatter",
    "javascript",
    "lint",
    "linter",
    "monorepo",
    "oxfmt",
    "oxfmt-config",
    "oxlint",
    "oxlint-config",
    "typescript"
  ],
  "license": "MIT",
  "author": "nbsp1221",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=main",
    "changeset:version": "changeset version && oxfmt .",
    "check": "pnpm build && pnpm typecheck:raw && pnpm lint:check:raw && pnpm format:check:raw && pnpm test:run",
    "format": "pnpm build && oxfmt .",
    "format:check": "pnpm build && pnpm format:check:raw",
    "format:check:raw": "oxfmt --check .",
    "lint": "pnpm build && pnpm lint:check:raw",
    "lint:check": "pnpm lint",
    "lint:check:raw": "oxlint . && eslint .",
    "lint:eslint": "pnpm build && eslint .",
    "lint:oxlint": "pnpm build && oxlint .",
    "release": "pnpm check && git diff --exit-code && changeset publish",
    "test": "pnpm build && pnpm test:run",
    "test:fixtures": "pnpm build && vitest run tests/integration/eslint-config.fixtures.test.ts",
    "test:run": "vitest run",
    "test:update-fixtures": "UPDATE_FIXTURES=1 pnpm test:fixtures",
    "test:watch": "pnpm build && vitest",
    "typecheck": "pnpm build && pnpm typecheck:raw",
    "typecheck:raw": "tsc --noEmit"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@retn0/common": "workspace:*",
    "@retn0/eslint-config": "workspace:*",
    "@retn0/eslint-config-oxlint": "workspace:*",
    "@retn0/oxfmt-config": "workspace:*",
    "@retn0/oxlint-config": "workspace:*",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "eslint": "10.7.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.25.0",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.34.3"
}
